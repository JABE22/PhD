\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Сводка классификации предложений ($N=168$ предложений, семь моделей). (a)~Распределение исходов классификации; распределение доминируется трассируемыми категориями, согласующимися с низкой операциональной онтологической новизной при калиброванных порогах. (b)~Распределения баллов новизны по категориям классификации (box plot).}}{9}{figure.1}\protected@file@percent }
\newlabel{fig:classification}{{1}{9}{Сводка классификации предложений ($N=168$ предложений, семь моделей). (a)~Распределение исходов классификации; распределение доминируется трассируемыми категориями, согласующимися с низкой операциональной онтологической новизной при калиброванных порогах. (b)~Распределения баллов новизны по категориям классификации (box plot)}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Геометрия пространства эмбеддингов}{9}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Распределения по полосам границы новизны и распределение баллов. (a)~Распределения полос по моделям: ответы концентрируются в зонах низкой новизны и близости к границе новизны во всех семи архитектурах, что указывает на архитектурно-независимые паттерны ограничений, а не на изолированные провалы конкретных моделей. (b)~Общее распределение непрерывного балла новизны с наложением оценки плотности; пунктирная линия показывает медиану.}}{10}{figure.2}\protected@file@percent }
\newlabel{fig:frontier_bands}{{2}{10}{Распределения по полосам границы новизны и распределение баллов. (a)~Распределения полос по моделям: ответы концентрируются в зонах низкой новизны и близости к границе новизны во всех семи архитектурах, что указывает на архитектурно-независимые паттерны ограничений, а не на изолированные провалы конкретных моделей. (b)~Общее распределение непрерывного балла новизны с наложением оценки плотности; пунктирная линия показывает медиану}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Декомпозиция критериев границы новизны по моделям. (a)~Абсолютный средний вклад каждого критерия в общую дистанцию до границы новизны. (b)~Относительная доля (\%) дистанции до границы новизны по критериям. Обе панели подтверждают, что большинство ответов нарушают несколько критериев одновременно, что поддерживает интерпретацию сопряжённых ограничений низкой онтологической новизны.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:frontier_decomp}{{3}{10}{Декомпозиция критериев границы новизны по моделям. (a)~Абсолютный средний вклад каждого критерия в общую дистанцию до границы новизны. (b)~Относительная доля (\%) дистанции до границы новизны по критериям. Обе панели подтверждают, что большинство ответов нарушают несколько критериев одновременно, что поддерживает интерпретацию сопряжённых ограничений низкой онтологической новизны}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Анализ пространства эмбеддингов для предложений эксперимента и обучающих модальностей. Принадлежность выпуклой оболочке вычисляется в PCA-редуцированном 3D пространстве; показанная 2D граница носит иллюстративный характер. Все 168 точек предложений кластеризуются рядом с внутренней частью обучающего многообразия --- ни одна не выходит в семантически изолированную область.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:embedding}{{4}{11}{Анализ пространства эмбеддингов для предложений эксперимента и обучающих модальностей. Принадлежность выпуклой оболочке вычисляется в PCA-редуцированном 3D пространстве; показанная 2D граница носит иллюстративный характер. Все 168 точек предложений кластеризуются рядом с внутренней частью обучающего многообразия --- ни одна не выходит в семантически изолированную область}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Сравнение моделей}{11}{subsection.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Агрегированное косинусное сходство предложенных модальностей с восьмью обучающими модальностями. Концентрация значений сходства подтверждает вывод о трассируемости: нет ни одного предложения, одновременно несходного со всеми восемью обучающими типами.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:similarity_heatmap}{{5}{12}{Агрегированное косинусное сходство предложенных модальностей с восьмью обучающими модальностями. Концентрация значений сходства подтверждает вывод о трассируемости: нет ни одного предложения, одновременно несходного со всеми восемью обучающими типами}{figure.5}{}}
