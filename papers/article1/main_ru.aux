\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Канонические кластеры предложений по моделям. Межмодельная вариативность проявляется преимущественно как различия предпочтений между существующими каноническими семействами (расширение диапазона, гибридная комбинация, функциональная рекомбинация), а не как появление качественно новых онтологических семейств.}}{13}{figure.6}\protected@file@percent }
\newlabel{fig:canonical_heatmap}{{6}{13}{Канонические кластеры предложений по моделям. Межмодельная вариативность проявляется преимущественно как различия предпочтений между существующими каноническими семействами (расширение диапазона, гибридная комбинация, функциональная рекомбинация), а не как появление качественно новых онтологических семейств}{figure.6}{}}
