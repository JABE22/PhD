\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Novelty-frontier criterion decomposition by model. (a)~Absolute mean contribution of each criterion to overall frontier distance. (b)~Relative share (\%) of frontier distance per criterion. Both panels confirm that most responses violate multiple criteria simultaneously, supporting a coupled-constraint interpretation of low ontological novelty.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:frontier_decomp}{{3}{9}{Novelty-frontier criterion decomposition by model. (a)~Absolute mean contribution of each criterion to overall frontier distance. (b)~Relative share (\%) of frontier distance per criterion. Both panels confirm that most responses violate multiple criteria simultaneously, supporting a coupled-constraint interpretation of low ontological novelty}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Embedding-space analysis for proposals and training modalities. Convex-hull membership is computed in PCA-reduced 3D space; the 2D boundary shown is illustrative only. All 168 proposal markers cluster near the interior of the training manifold---none escape to a semantically isolated region.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:embedding}{{4}{9}{Embedding-space analysis for proposals and training modalities. Convex-hull membership is computed in PCA-reduced 3D space; the 2D boundary shown is illustrative only. All 168 proposal markers cluster near the interior of the training manifold---none escape to a semantically isolated region}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Aggregated cosine similarity of proposed modalities to the eight training modalities. Concentration of similarity values confirms the traceability finding: no proposal is simultaneously dissimilar from all eight training types.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:similarity_heatmap}{{5}{10}{Aggregated cosine similarity of proposed modalities to the eight training modalities. Concentration of similarity values confirms the traceability finding: no proposal is simultaneously dissimilar from all eight training types}{figure.5}{}}
