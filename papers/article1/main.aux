\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Classification summary ($N=168$ proposals, seven models). (a)~Distribution of classification outcomes; the distribution is dominated by traceable categories consistent with low operational ontological novelty under calibrated thresholds. (b)~Novelty score distributions by classification category shown as box plots.}}{7}{figure.1}\protected@file@percent }
